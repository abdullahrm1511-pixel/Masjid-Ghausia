generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  DONOR
  REGISTRATION_ADMIN
  ADMIN
  SUPER_ADMIN
}

enum DonorStatus {
  PENDING
  ACTIVE
  ACTION_REQUIRED
  INACTIVE
  REJECTED
  DECEASED
  PAYMENT_REQUIRED
}

enum FamilyMemberType {
  PARTNER
  CHILD
  OTHER
}

enum FamilyMemberStatus {
  ACTIVE_DEPENDENT
  UNDER_18
  ADULT_NEEDS_REGISTRATION
  REGISTERED_SEPARATELY
  NOT_A_MEMBER
  DECEASED
}

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  WIDOWED
  DIVORCED
}

enum RegistrationRequestStatus {
  DRAFT
  PENDING
  ACTION_REQUIRED
  APPROVED
  REJECTED
  CANCELLED
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  STATUS_CHANGE
}

enum PaymentObligationType {
  ONE_TIME
  ANNUAL
  MANUAL
}

enum PaymentObligationStatus {
  DUE
  PAID
  WAIVED
  MANUAL_CORRECTION
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  EXTERNAL_IDEAL
  EXTERNAL_SEPA
  OTHER
}

enum MembershipMemberRole {
  PRIMARY
  PARTNER
  CHILD
}

enum MembershipChangeType {
  ADD_PARTNER
  DIVORCE
  PARTNER_DECEASED
  CHILD_CUSTODY_CHANGE
  PARTNER_OWN_MEMBERSHIP
  CHILD_TURNING_18
}

enum MembershipChangeStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AdultChildTransitionStatus {
  NEEDS_REGISTRATION
  INVITED
  REGISTERED
  DISMISSED
}

enum EmailLogStatus {
  PREPARED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(DONOR)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts                   Account[]
  sessions                   Session[]
  donorProfile               DonorProfile?
  adminProfile               AdminProfile?
  auditLogs                  AuditLog[]
  updatedPayments            PaymentObligation[]         @relation("PaymentUpdatedBy")
  statusChanges              DonorStatusHistory[]        @relation("StatusChangedBy")
  familyStatusChanges        FamilyMemberStatusHistory[] @relation("FamilyStatusChangedBy")
  adultTransitionsResolved   AdultChildTransition[]      @relation("AdultTransitionResolvedBy")
  passwordResetTokens        PasswordResetToken[]
  registrationRequests       RegistrationRequest[]
  reviewedRegistrations      RegistrationRequest[]       @relation("ReviewedRegistrations")
  submittedChangeRequests    ChangeRequest[]             @relation("SubmittedChangeRequests")
  reviewedChangeRequests     ChangeRequest[]             @relation("ReviewedChangeRequests")
  submittedMembershipChanges MembershipChangeRequest[]   @relation("SubmittedMembershipChanges")
  reviewedMembershipChanges  MembershipChangeRequest[]   @relation("ReviewedMembershipChanges")
}

model DonorProfile {
  id                   String         @id @default(cuid())
  userId               String         @unique
  currentMembershipId  String?
  registrationNumber   String?        @unique
  legacyMemberDetailKey String?
  legacyAddressKey     String?
  status               DonorStatus    @default(PENDING)
  firstName            String
  lastName             String
  gender               Gender?
  phone                String
  addressLine1         String
  addressLine2         String?
  postalCode           String
  city                 String
  country              String         @default("NL")
  dateOfBirth          DateTime
  birthPlace           String
  iban                 String
  accountHolderName    String
  maritalStatus        MaritalStatus?
  pakistanContactName  String?
  pakistanContactPhone String?
  funeralWishes        String?
  notes                String?
  approvedAt           DateTime?
  statusChangedAt      DateTime?
  activeSince          DateTime?
  inactiveSince        DateTime?
  deceasedAt           DateTime?
  statusInternalNote   String?
  statusDonorMessage   String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user                 User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentMembership    Membership?                 @relation("CurrentMembership", fields: [currentMembershipId], references: [id], onDelete: SetNull)
  primaryMemberships   Membership[]                @relation("MembershipPrimary")
  payerMemberships     Membership[]                @relation("MembershipPayer")
  membershipMembers    MembershipMember[]
  familyMembers        FamilyMember[]
  registrationRequests RegistrationRequest[]
  changeRequests       ChangeRequest[]
  paymentObligations   PaymentObligation[]
  statusHistory        DonorStatusHistory[]
  familyStatusHistory  FamilyMemberStatusHistory[]
  previousAdultChildTransitions AdultChildTransition[] @relation("AdultTransitionPreviousDonor")
  newAdultChildTransitions      AdultChildTransition[] @relation("AdultTransitionNewDonor")

  @@index([registrationNumber])
  @@index([legacyMemberDetailKey])
  @@index([legacyAddressKey])
  @@index([currentMembershipId])
  @@index([status])
  @@index([iban])
}

model DonorStatusHistory {
  id             String       @id @default(cuid())
  donorProfileId String
  changedById    String?
  fromStatus     DonorStatus?
  toStatus       DonorStatus
  internalNote   String
  donorMessage   String
  createdAt      DateTime     @default(now())

  donorProfile DonorProfile @relation(fields: [donorProfileId], references: [id], onDelete: Cascade)
  changedBy    User?        @relation("StatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([donorProfileId])
  @@index([changedById])
  @@index([toStatus])
  @@index([createdAt])
}

model FamilyMember {
  id             String           @id @default(cuid())
  donorProfileId String
  legacyMemberDetailKey String?
  legacyAddressKey String?
  type           FamilyMemberType
  status         FamilyMemberStatus @default(ACTIVE_DEPENDENT)
  firstName      String
  lastName       String
  gender         Gender?
  dateOfBirth    DateTime
  birthPlace     String?
  relationship   String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  donorProfile      DonorProfile                @relation(fields: [donorProfileId], references: [id], onDelete: Cascade)
  membershipMembers MembershipMember[]
  statusHistory     FamilyMemberStatusHistory[]
  adultTransition    AdultChildTransition?

  @@index([legacyMemberDetailKey])
  @@index([legacyAddressKey])
  @@index([status])
  @@index([type, status])
}

model FamilyMemberStatusHistory {
  id             String   @id @default(cuid())
  familyMemberId String
  donorProfileId String
  changedById    String?
  fromStatus     String
  toStatus       String
  internalNote   String
  donorMessage   String
  createdAt      DateTime @default(now())

  familyMember FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  donorProfile DonorProfile @relation(fields: [donorProfileId], references: [id], onDelete: Cascade)
  changedBy    User?        @relation("FamilyStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([familyMemberId])
  @@index([donorProfileId])
  @@index([changedById])
  @@index([createdAt])
}

model AdultChildTransition {
  id                    String                     @id @default(cuid())
  familyMemberId        String                     @unique
  previousDonorProfileId String
  newDonorProfileId     String?
  status                AdultChildTransitionStatus @default(NEEDS_REGISTRATION)
  turned18At            DateTime
  notes                 String?
  resolvedById          String?
  resolvedAt            DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  familyMember         FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  previousDonorProfile DonorProfile @relation("AdultTransitionPreviousDonor", fields: [previousDonorProfileId], references: [id], onDelete: Cascade)
  newDonorProfile      DonorProfile? @relation("AdultTransitionNewDonor", fields: [newDonorProfileId], references: [id], onDelete: SetNull)
  resolvedBy           User?        @relation("AdultTransitionResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([previousDonorProfileId])
  @@index([newDonorProfileId])
  @@index([status])
  @@index([turned18At])
}

model Membership {
  id                        String      @id @default(cuid())
  registrationNumber        String      @unique
  status                    DonorStatus @default(PENDING)
  primaryDonorProfileId     String?
  annualPayerDonorProfileId String?
  notes                     String?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  primaryDonorProfile     DonorProfile?             @relation("MembershipPrimary", fields: [primaryDonorProfileId], references: [id], onDelete: SetNull)
  annualPayerDonorProfile DonorProfile?             @relation("MembershipPayer", fields: [annualPayerDonorProfileId], references: [id], onDelete: SetNull)
  currentDonorProfiles    DonorProfile[]            @relation("CurrentMembership")
  members                 MembershipMember[]
  paymentObligations      PaymentObligation[]
  changeRequests          MembershipChangeRequest[]

  @@index([status])
  @@index([primaryDonorProfileId])
  @@index([annualPayerDonorProfileId])
}

model MembershipMember {
  id             String               @id @default(cuid())
  membershipId   String
  donorProfileId String?
  familyMemberId String?
  role           MembershipMemberRole
  displayNumber  String?
  isPrimaryPayer Boolean              @default(false)
  isActive       Boolean              @default(true)
  activeFrom     DateTime             @default(now())
  endedAt        DateTime?
  endReason      String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  membership   Membership    @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  donorProfile DonorProfile? @relation(fields: [donorProfileId], references: [id], onDelete: SetNull)
  familyMember FamilyMember? @relation(fields: [familyMemberId], references: [id], onDelete: SetNull)

  @@unique([membershipId, donorProfileId])
  @@unique([membershipId, familyMemberId])
  @@index([membershipId])
  @@index([donorProfileId])
  @@index([familyMemberId])
  @@index([role])
}

model MembershipChangeRequest {
  id            String                 @id @default(cuid())
  membershipId  String
  requestedById String
  reviewedById  String?
  changeType    MembershipChangeType
  status        MembershipChangeStatus @default(PENDING)
  requestedData Json
  currentData   Json?
  memberNote    String?
  adminNote     String?
  memberMessage String?
  submittedAt   DateTime               @default(now())
  reviewedAt    DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  membership  Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  requestedBy User       @relation("SubmittedMembershipChanges", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy  User?      @relation("ReviewedMembershipChanges", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([membershipId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([status])
  @@index([changeType])
  @@index([submittedAt])
}

model RegistrationRequest {
  id              String                    @id @default(cuid())
  requestedById   String
  donorProfileId  String?
  reviewedById    String?
  status          RegistrationRequestStatus @default(PENDING)
  submittedData   Json
  reviewNotes     String?
  donorMessage    String?
  rejectionReason String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  requestedBy  User          @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  donorProfile DonorProfile? @relation(fields: [donorProfileId], references: [id], onDelete: SetNull)
  reviewedBy   User?         @relation("ReviewedRegistrations", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model ChangeRequest {
  id             String              @id @default(cuid())
  donorProfileId String
  submittedById  String
  reviewedById   String?
  status         ChangeRequestStatus @default(PENDING)
  changeType     String
  requestedData  Json
  currentData    Json
  donorNote      String?
  adminNote      String?
  donorMessage   String?
  submittedAt    DateTime            @default(now())
  reviewedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  donorProfile DonorProfile @relation(fields: [donorProfileId], references: [id], onDelete: Cascade)
  submittedBy  User         @relation("SubmittedChangeRequests", fields: [submittedById], references: [id], onDelete: Cascade)
  reviewedBy   User?        @relation("ReviewedChangeRequests", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([submittedAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  action     AuditAction
  entityType String
  entityId   String?
  message    String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model AdminProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  displayName         String
  twoFactorRequired   Boolean   @default(true)
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  twoFactorVerifiedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RegistrationCounter {
  id        String   @id @default(cuid())
  prefix    String   @unique
  current   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentObligation {
  id               String                  @id @default(cuid())
  donorProfileId   String
  membershipId     String?
  updatedByAdminId String?
  lidnummer        String?
  obligationType   PaymentObligationType
  amountCents      Int
  status           PaymentObligationStatus @default(DUE)
  paymentMethod    PaymentMethod?
  dueDate          DateTime?
  paidAt           DateTime?
  notes            String?
  adminNote        String?
  source           String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  donorProfile   DonorProfile @relation(fields: [donorProfileId], references: [id], onDelete: Cascade)
  membership     Membership?  @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  updatedByAdmin User?        @relation("PaymentUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)

  @@index([donorProfileId])
  @@index([membershipId])
  @@index([updatedByAdminId])
  @@index([lidnummer])
  @@index([status])
  @@index([source])
}

model EmailTemplate {
  id                    String   @id @default(cuid())
  key                   String   @unique
  name                  String
  subject               String
  bodyHtml              String
  bodyText              String?
  availablePlaceholders Json
  isSystem              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([key])
}

model EmailLog {
  id          String         @id @default(cuid())
  templateKey String
  recipient   String
  subject     String
  bodyHtml    String
  bodyText    String?
  status      EmailLogStatus @default(PREPARED)
  entityType  String?
  entityId    String?
  createdAt   DateTime       @default(now())

  @@index([templateKey])
  @@index([recipient])
  @@index([entityType, entityId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
